generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  clerkId             String               @unique
  email               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  delayEvents         DelayEvent[]
  claimProfile        ClaimProfile?
  operatorCredentials OperatorCredential[]
  tflCredential       TflCredential?
  successFees         SuccessFee[]
}

model ClaimProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName               String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  postcode                String?
  phone                   String?
  payoutPreference        String   @default("bank") // bank | paypal | voucher — TOC still pays Fifteen
  defaultTicketType       String   @default("contactless")
  autoSubmitConsent       Boolean  @default(false)
  /// Passenger bank for Fifteen → user Mollie payout
  bankAccountName         String?
  bankSortCode            String?
  bankAccountNumber       String?
  mollieCustomerId        String?
  bankConnectedAt         DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model OperatorCredential {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  operator           String
  portalEmail        String
  passwordCiphertext String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, operator])
  @@index([userId])
}

model TflCredential {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  portalEmail        String
  passwordCiphertext String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DelayEvent {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  operator                String
  originCrs               String
  originName              String
  destinationCrs          String
  destinationName         String
  serviceUid              String
  runDate                 String
  scheduledArrival        String
  actualArrival           String
  delayMinutes            Int
  ticketType              String
  ticketPricePence        Int
  compensationTier        String
  compensationAmountPence Int
  claimSummary            String
  status                  String    @default("unclaimed")
  workflowRunId           String?
  portalClaimRef          String?
  submitError             String?
  submittedAt             DateTime?
  evidencePath            String?
  evidenceMime            String?
  tflJourneyId            String?
  contactlessFarePence    Int?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  successFee              SuccessFee?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@unique([userId, serviceUid, runDate])
}

/// Settlement when Fifteen receives Delay Repay and pays the passenger (minus fee).
model SuccessFee {
  id                       String     @id @default(cuid())
  delayEventId             String     @unique
  delayEvent               DelayEvent @relation(fields: [delayEventId], references: [id], onDelete: Cascade)
  userId                   String
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  compensationAmountPence  Int
  userPayoutPence          Int        @default(0)
  commissionPence          Int
  charityPence             Int
  totalFeePence            Int
  /// awaiting_funds | ready | paid_out | failed
  status                   String     @default("awaiting_funds")
  molliePaymentId          String?    @unique
  checkoutUrl              String?
  paidAt                   DateTime?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([userId, status])
  @@index([molliePaymentId])
}
