# Supabase Postgres — use transaction pooler (:6543) for the app runtime
# Dashboard → Connect → Transaction pooler. Append ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler or direct connection (:5432) for Prisma migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Storage (server-side evidence uploads)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# Service role key — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Realtime Trains — api-portal.rtt.io token (refresh or access).
# Refresh tokens are exchanged automatically via /api/get_access_token.
RTT_TOKEN=

# Legacy Basic Auth only (optional) — leave blank if using RTT_TOKEN
RTT_USERNAME=
RTT_PASSWORD=

# Auto Delay Repay
# mock (default, required on Vercel) | live — live uses Playwright locally only
CLAIM_SUBMIT_MODE=mock
# AES key for TOC/TfL passwords (64 hex chars recommended, or any passphrase)
# Required in production
CREDENTIALS_ENCRYPTION_KEY=
# Set to 1 to run Playwright headed for debugging (local live mode only)
# PLAYWRIGHT_HEADED=1

# Mollie — receive Delay Repay, then pay passenger (bank connect + payout)
# https://my.mollie.com/dashboard → Developers → API keys
MOLLIE_API_KEY=
# Optional: charity org for live split routing (leave blank to ledger charity only)
MOLLIE_CHARITY_ORG_ID=
# Public app URL (webhooks only when not localhost)
NEXT_PUBLIC_APP_URL=http://localhost:3000
