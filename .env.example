# Database (SQLite for local hackathon)
DATABASE_URL="file:./prisma/dev.db"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Realtime Trains — api-portal.rtt.io token (refresh or access).
# Refresh tokens are exchanged automatically via /api/get_access_token.
RTT_TOKEN=

# Legacy Basic Auth only (optional) — leave blank if using RTT_TOKEN
RTT_USERNAME=
RTT_PASSWORD=

# Auto Delay Repay
# mock (default) | live — live uses Playwright against TfL + TOC portals
CLAIM_SUBMIT_MODE=mock
# AES key for TOC/TfL passwords (64 hex chars recommended, or any passphrase)
CREDENTIALS_ENCRYPTION_KEY=
# Set to 1 to run Playwright headed for debugging
# PLAYWRIGHT_HEADED=1
